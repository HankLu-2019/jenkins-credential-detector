# Copy to .env and fill in values before running docker compose

POSTGRES_USER=sentinel
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sentinel

# Override the database URL if using an external PostgreSQL
DATABASE_URL=postgresql://sentinel:changeme@postgres:5432/sentinel

# Path on the Docker host to mount as the Jenkins jobs directory (read-only)
# Set one per Jenkins instance; additional instances require separate volume entries
JENKINS_JOBS_PATH=/home/jobs

# Ollama model to pull and use
OLLAMA_MODEL=qwen2.5-coder:7b
